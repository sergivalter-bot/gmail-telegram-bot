# ─────────────────────────────────────────────
#  Gmail → Telegram Payment Bot  –  .env file
# ─────────────────────────────────────────────

# Your Gmail address
GMAIL_USER=office@spmovers.com

# Gmail App Password (NOT your regular password!)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on your Google account.
GMAIL_APP_PASSWORD=bzfn jcwc uaqr pvvu

# Telegram Bot Token
# Get it from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=8685141484:AAGrTzuE0yNs8LDsG156zBvFkWYsbxrc15o

# Telegram Chat ID where notifications will be sent
# For a personal chat: open https://api.telegram.org/bot<TOKEN>/getUpdates
#   after sending any message to the bot, then look for "chat" → "id"
# For a group: add the bot to the group, send a message,
#   then do the same getUpdates call — the id will be negative (e.g. -1001234567890)
TELEGRAM_CHAT_ID=-1003793622465

# How often to check Gmail (in seconds). Default: 60
CHECK_INTERVAL_SECONDS=60

# The sender email to monitor (do not change unless the sender changes)
PAYMENT_SENDER=payments@anywherecommerce.com
